{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "Pole Position Brand Tokens",
  "version": "1.1.0",
  "description": "Single source of truth for the Pole Position visual identity. Champion system, derived directly from the gold + checkered-flag + speed-red logo. Change a value here and update tokens.css + tailwind.preset.js to keep them in sync.",
  "color": {
    "surface": {
      "lights-out": { "value": "#0B0D12", "usage": "Primary background. Near-neutral racing black; lets gold + checkered pop." },
      "carbon":     { "value": "#15171E", "usage": "Elevated surfaces: cards, sheets, nav." },
      "pit-wall":   { "value": "#1F222B", "usage": "Inputs, secondary surfaces, hover fills." },
      "line":       { "value": "#2C313C", "usage": "Borders, dividers, hairlines." }
    },
    "flag": {
      "white": { "value": "#FFFFFF", "usage": "Checkered-flag light square. Pure white." },
      "black": { "value": "#0A0A0A", "usage": "Checkered-flag dark square. Pure black, distinct from surfaces." }
    },
    "gold": {
      "200": { "value": "#FFE6A8", "usage": "Pale gold highlight; gold text/links ON dark." },
      "400": { "value": "#F4CB6A", "usage": "Light gold, secondary accents." },
      "500": { "value": "#E9B23A", "usage": "PRIMARY brand. Champion / pole / winner / P1. CTAs, the glow." },
      "700": { "value": "#B8780F", "usage": "Bronze shadow; pressed/hover on gold fills." },
      "900": { "value": "#3D2A07", "usage": "Subtle tinted background fills, chips." }
    },
    "red": {
      "400": { "value": "#FF5A4D", "usage": "Speed/danger text on dark." },
      "500": { "value": "#E00000", "usage": "Speed accent, lock-in, DNF, danger, the model. Hot red from the logo." },
      "700": { "value": "#A60000", "usage": "Pressed danger state." },
      "orange": { "value": "#FF3B00", "usage": "Speed-streak gradient endpoint only." }
    },
    "green": {
      "400": { "value": "#5CFFA8", "usage": "Success text on dark." },
      "500": { "value": "#00E676", "usage": "GO / correct pick / leaderboard climb. Functional success only." },
      "700": { "value": "#00B85E", "usage": "Pressed success state." }
    },
    "text": {
      "primary":   { "value": "#FFFFFF", "usage": "Headlines, key numbers." },
      "secondary": { "value": "#E8EAED", "usage": "Body copy (Ghost)." },
      "muted":     { "value": "#9AA3AF", "usage": "Secondary copy, captions." },
      "faint":     { "value": "#5A626E", "usage": "Labels, disabled. LARGE text only — fails AA at body size." }
    }
  },
  "gradient": {
    "gold":  { "value": "linear-gradient(135deg, #FFE6A8 0%, #E9B23A 45%, #B8780F 100%)", "usage": "Metallic gold sheen — primary CTA fills, P1 / winner, the logo lockup. Matches the logo's gold." },
    "speed": { "value": "linear-gradient(135deg, #FF3B00 0%, #E00000 100%)", "usage": "Red-to-orange speed streak. Motion accents, urgency. Sparingly." }
  },
  "font": {
    "family": {
      "display": { "value": "\"Saira\", system-ui, sans-serif", "usage": "Headlines, hero, big race statements. Weights 600-900." },
      "body":    { "value": "\"Inter\", system-ui, sans-serif", "usage": "All UI and body copy. Weights 400-700." },
      "mono":    { "value": "\"JetBrains Mono\", ui-monospace, monospace", "usage": "Scores, timers, leaderboards, labels. Always tabular-nums." }
    },
    "scale": {
      "display-xl": { "size": "64px", "line": "1.0",  "weight": "800", "family": "display" },
      "display-l":  { "size": "48px", "line": "1.05", "weight": "800", "family": "display" },
      "h1":         { "size": "36px", "line": "1.1",  "weight": "700", "family": "display" },
      "h2":         { "size": "28px", "line": "1.15", "weight": "700", "family": "display" },
      "h3":         { "size": "22px", "line": "1.2",  "weight": "600", "family": "display" },
      "body-l":     { "size": "18px", "line": "1.5",  "weight": "400", "family": "body" },
      "body":       { "size": "16px", "line": "1.55", "weight": "400", "family": "body" },
      "body-s":     { "size": "14px", "line": "1.5",  "weight": "400", "family": "body" },
      "label":      { "size": "12px", "line": "1.2",  "weight": "600", "family": "mono", "transform": "uppercase", "tracking": "0.08em" },
      "data-xl":    { "size": "56px", "line": "1.0",  "weight": "700", "family": "mono", "feature": "tabular-nums" },
      "data":       { "size": "18px", "line": "1.2",  "weight": "500", "family": "mono", "feature": "tabular-nums" }
    }
  },
  "space": {
    "0": "0px", "1": "4px", "2": "8px", "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px", "12": "48px",
    "16": "64px", "20": "80px"
  },
  "radius": { "sm": "6px", "md": "10px", "lg": "16px", "xl": "24px", "pill": "9999px" },
  "shadow": {
    "elev-1":    { "value": "0 1px 2px rgba(0,0,0,0.40)" },
    "elev-2":    { "value": "0 4px 12px rgba(0,0,0,0.50)" },
    "glow-gold": { "value": "0 0 24px rgba(233,178,58,0.40)", "usage": "Active CTA, focus, winner / P1 state." },
    "glow-red":  { "value": "0 0 20px rgba(224,0,0,0.32)",   "usage": "Lock-in / urgent moments." }
  }
}
